# From Convex dashboard / `npx convex dev` output
NEXT_PUBLIC_CONVEX_URL=

# Optional: used by Convex CLI tooling (often written to `.env.local` automatically)
# CONVEX_DEPLOYMENT=

# Set in Convex dashboard → Settings → Environment variables
# SEED_SECRET=your-long-random-secret
# Phase 3 payments (mock until Hubtel is configured)
# PAYMENT_PROVIDER=mock

# CLI seed only (optional — prefer /admin/setup in the browser)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_NAME=
